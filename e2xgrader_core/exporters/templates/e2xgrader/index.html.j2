{%- extends 'nbconvert/templates/classic/index.html.j2' -%}
{% block notebook_css %}
    {{ super() }}
    <style type="text/css">
    /* Custom styles for e2xgrader */
    :root {
      --e2xgrader-light-blue: #d8f3ff;
      --e2xgrader-blue: #3ac4ff;
      --e2xgrader-dark-blue: #005d92;
      --e2xgrader-gray: #eee;
    }
    </style>
{% endblock notebook_css %}

{% block markdowncell scoped %}
<div class="cell border-box-sizing text_cell rendered{{ celltags(cell) }}">
{%- if resources.global_content_filter.include_input_prompt-%}
    {{ self.empty_in_prompt() }}
{%- endif -%}
<div class="inner_cell">
<div class="text_cell_render border-box-sizing rendered_html">
{{ cell.source  | markdown2html | strip_files_prefix | to_e2xgrader_cell }}
</div>
</div>
</div>
{%- endblock markdowncell %}